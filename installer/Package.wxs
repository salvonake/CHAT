<?xml version="1.0" encoding="UTF-8"?>
<!--
    Poseidon Desktop â€” WiX v5 MSI Installer
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    Evidence-Constrained Legal Decision Support System (LCDSS)

    Key design points:
    â€¢ Single MSI file for enterprise / air-gapped deployment
    â€¢ Bundles ~10 GB GGUF model + AraBERT ONNX as selectable features
    â€¢ per-Machine install into Program Files\Poseidon
    â€¢ Data directory in %LOCALAPPDATA%\Poseidon\Data
    â€¢ Arabic + English bilingual UI strings
    â€¢ Silent install support: msiexec /i Poseidon.Installer.msi /qn
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="$(var.ProductNameEn)"
           Manufacturer="$(var.Manufacturer)"
           Version="$(var.ProductVersion)"
           UpgradeCode="$(var.UpgradeCode)"
           Language="1036"
           Codepage="1252"
           InstallerVersion="500"
           Compressed="yes"
           Scope="perMachine">

    <!-- â•â•â• Upgrade logic â•â•â• -->
    <MajorUpgrade DowngradeErrorMessage=
      "Une version plus recente est deja installee."/>

    <!-- â•â•â• Single embedded CAB for offline deployment â•â•â• -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high"/>

    <!-- â•â•â• System requirements â•â•â• -->
    <Launch Condition="VersionNT64"
          Message="Cette application requiert Windows 64 bits."/>

    <!-- â•â•â• Feature tree â•â•â• -->
    <Feature Id="CoreFeature"
             Title="Poseidon Desktop"
             Description="Application principale de support juridique base sur des preuves"
             Level="1"
             ConfigurableDirectory="INSTALLDIR"
             AllowAbsent="no">
      <ComponentGroupRef Id="AppFiles"/>
      <ComponentRef Id="DesktopShortcutComp"/>
      <ComponentRef Id="StartMenuShortcutComp"/>
      <ComponentRef Id="DataDirectoryComp"/>
      <ComponentRef Id="ModelsDirectoryComp"/>
      <ComponentRef Id="AppDataRootComp"/>
      <ComponentRef Id="RegistryComp"/>
      <ComponentRef Id="ProvisioningCheckComp"/>
      <ComponentRef Id="MachineConfigComp"/>
      <ComponentRef Id="ModelManifestComp"/>
    </Feature>

    <?if $(var.InstallerMode) = full ?>
    <Feature Id="ModelFeature"
             Title="Modele LLM - Qwen 2.5 14B Q5_K_M"
             Description="Modele de langage (~10 Go) requis pour les reponses juridiques"
             Level="1"
             AllowAbsent="yes">
      <ComponentGroupRef Id="ModelFiles"/>
    </Feature>
    <?endif?>

    <Feature Id="EmbeddingFeature"
             Title="AraBERT Embedding Model (ONNX)"
             Description="Modele d'embedding requis pour l'indexation des documents"
             Level="1"
             AllowAbsent="no">
      <ComponentGroupRef Id="EmbeddingFiles"/>
    </Feature>

    <!-- â•â•â• UI â•â•â• -->
    <ui:WixUI Id="WixUI_FeatureTree"
              InstallDirectory="INSTALLDIR"/>
    <UIRef Id="WixUI_ErrorProgressText"/>

    <!-- â•â•â• Icon / ARP â•â•â• -->
    <Icon Id="Poseidon.ico" SourceFile="Resources\Poseidon.ico"/>
    <Property Id="ARPPRODUCTICON" Value="Poseidon.ico"/>
    <Property Id="ARPHELPLINK"    Value="https://poseidon.local"/>
    <Property Id="ARPURLINFOABOUT" Value="https://poseidon.local"/>

    <CustomAction Id="RunProvisioningCheck"
                  FileRef="ProvisioningCheckExe"
                  ExeCommand="--config &quot;[INSTALLDIR]appsettings.user.json&quot; --manifest &quot;[ModelsDir]model-manifest.json&quot; --install-dir &quot;[INSTALLDIR].&quot; --mode &quot;$(var.InstallerMode)&quot; --log &quot;[LocalAppDataFolder]Poseidon\Logs\startup.log&quot;"
                  Execute="deferred"
                  Return="check"
                  Impersonate="no"/>

    <InstallExecuteSequence>
      <Custom Action="RunProvisioningCheck" After="InstallFiles" Condition="NOT REMOVE=&quot;ALL&quot;"/>
    </InstallExecuteSequence>

  </Package>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       DIRECTORY LAYOUT
       â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="Poseidon">
        <Directory Id="ModelsDir" Name="Models"/>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder"/>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuDir" Name="Poseidon"/>
    </StandardDirectory>

    <!-- Data directory: %LOCALAPPDATA%\Poseidon\Data -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="PoseidonAppData" Name="Poseidon">
        <Directory Id="PoseidonDataDir"   Name="Data"/>
        <Directory Id="PoseidonModelsDir" Name="Models"/>
      </Directory>
    </StandardDirectory>
  </Fragment>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       SHORTCUTS + REGISTRY
       â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Fragment>
    <!-- Desktop shortcut -->
    <Component Id="DesktopShortcutComp"
               Directory="DesktopFolder"
               Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
      <Shortcut Id="DesktopShortcutLink"
                Name="Poseidon"
                Description="Evidence-Constrained Legal Decision Support System"
                Target="[INSTALLDIR]Poseidon.Desktop.exe"
                WorkingDirectory="INSTALLDIR"
                Icon="Poseidon.ico"/>
      <RegistryValue Root="HKCU"
                     Key="Software\Poseidon"
                     Name="DesktopShortcut"
                     Type="integer" Value="1" KeyPath="yes"/>
    </Component>

    <!-- Start menu shortcut -->
    <Component Id="StartMenuShortcutComp"
               Directory="StartMenuDir"
               Guid="B2C3D4E5-F6A7-8901-BCDE-F23456789012">
      <Shortcut Id="StartMenuLink"
                Name="Poseidon"
                Description="Evidence-Constrained Legal Decision Support System"
                Target="[INSTALLDIR]Poseidon.Desktop.exe"
                WorkingDirectory="INSTALLDIR"
                Icon="Poseidon.ico"/>
      <RemoveFolder Id="RemoveStartMenuDir" On="uninstall"/>
      <RegistryValue Root="HKCU"
                     Key="Software\Poseidon"
                     Name="StartMenuShortcut"
                     Type="integer" Value="1" KeyPath="yes"/>
    </Component>

    <!-- Data directory created on install -->
    <Component Id="DataDirectoryComp"
               Directory="PoseidonDataDir"
               Guid="C3D4E5F6-A7B8-9012-CDEF-345678901234">
      <CreateFolder/>
      <RemoveFolder Id="RemovePoseidonDataDir" On="uninstall"/>
      <RegistryValue Root="HKCU"
                     Key="Software\Poseidon"
                     Name="DataDirCreated"
                     Type="integer" Value="1" KeyPath="yes"/>
    </Component>

    <Component Id="ModelsDirectoryComp"
               Directory="PoseidonModelsDir"
               Guid="A7D69010-2B9E-4E31-8B17-4A63F4D6A8F1">
      <CreateFolder/>
      <RemoveFolder Id="RemovePoseidonModelsDir" On="uninstall"/>
      <RegistryValue Root="HKCU"
                     Key="Software\Poseidon"
                     Name="ModelsDirCreated"
                     Type="integer" Value="1" KeyPath="yes"/>
    </Component>

    <Component Id="AppDataRootComp"
               Directory="PoseidonAppData"
               Guid="0CBE7F3B-14EE-4AF4-B57A-FF43CE6D83C4">
      <CreateFolder/>
      <RemoveFolder Id="RemovePoseidonAppData" On="uninstall"/>
      <RegistryValue Root="HKCU"
                     Key="Software\Poseidon"
                     Name="AppDataRootCreated"
                     Type="integer" Value="1" KeyPath="yes"/>
    </Component>

    <!-- Install path in registry (for upgrades / model location) -->
    <Component Id="RegistryComp"
               Directory="INSTALLDIR"
               Guid="D4E5F6A7-B8C9-0123-DEFA-456789012345">
      <RegistryKey Root="HKLM" Key="Software\Poseidon">
        <RegistryValue Name="InstallDir"  Type="string" Value="[INSTALLDIR]"/>
        <RegistryValue Name="Version"     Type="string" Value="$(var.ProductVersion)"/>
        <RegistryValue Name="ModelsDir"   Type="string" Value="[ModelsDir]"/>
      </RegistryKey>
    </Component>

    <Component Id="ProvisioningCheckComp"
               Directory="INSTALLDIR"
               Guid="3344972A-7493-4450-B2FD-742F0B41E94D">
      <File Id="ProvisioningCheckExe"
            Source="$(var.ProvisioningCheckPath)"
            Name="provisioning-check.exe"
            KeyPath="yes"/>
    </Component>

    <Component Id="MachineConfigComp"
               Directory="INSTALLDIR"
               Guid="3F826944-7252-44C8-A6A6-4548A98909BB">
      <File Id="MachineConfigFile"
            Source="$(var.MachineConfigPath)"
            Name="appsettings.user.json"
            KeyPath="yes"/>
    </Component>

    <Component Id="ModelManifestComp"
               Directory="ModelsDir"
               Guid="96C2473F-2F21-4212-A75B-B7912D06075F">
      <File Id="ModelManifestFile"
            Source="$(var.ModelManifestPath)"
            Name="model-manifest.json"
            KeyPath="yes"/>
    </Component>
  </Fragment>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       MODEL FILES (selectable feature)
       â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Fragment>
    <?if $(var.InstallerMode) = full ?>
    <ComponentGroup Id="ModelFiles" Directory="ModelsDir">
      <Component Id="LlmModelFileComp"
                 Guid="E5F6A7B8-C9D0-1234-EFAB-567890123456">
        <File Id="QwenModel"
            Source="$(var.ModelsPath)\$(var.LlmModelFileName)"
            Name="$(var.LlmModelFileName)"
              KeyPath="yes"/>
      </Component>
    </ComponentGroup>
    <?endif?>

    <ComponentGroup Id="EmbeddingFiles" Directory="ModelsDir">
      <Component Id="EmbeddingModelFileComp"
                 Guid="F6A7B8C9-D0E1-2345-FABC-678901234567">
        <File Id="AraBertModel"
              Source="$(var.ModelsPath)\arabert.onnx"
              Name="arabert.onnx"
              KeyPath="yes"/>
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>

