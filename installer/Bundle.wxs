<?xml version="1.0" encoding="UTF-8"?>
<!--
    Poseidon Desktop â€” WiX v5 Burn Bundle (.exe Installer)
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    Produces the official Poseidon.Bundle.exe that:
    â€¢ Shows a branded wizard UI (install / repair / uninstall)
    â€¢ Checks for .NET Desktop Runtime 8.x and installs it if missing
    â€¢ Checks for VC++ Redistributable (required by llama.cpp / CUDA)
    â€¢ Embeds the Poseidon MSI Package
    â€¢ Supports silent install: Poseidon.Bundle.exe /quiet
    â€¢ Supports passive (progress-only): Poseidon.Bundle.exe /passive
    â€¢ Logs: Poseidon.Bundle.exe /log install.log
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle Name="$(var.ProductNameEn)"
          Manufacturer="$(var.Manufacturer)"
          Version="1.0.2.1"
          UpgradeCode="$(var.BundleUpgradeCode)"
          IconSourceFile="Resources\Poseidon.ico"
          AboutUrl="https://poseidon.local"
          Compressed="yes">

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         Bootstrapper Application (UI)
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         WixStandardBootstrapperApplication provides a built-in
         wizard UI with Install / Repair / Uninstall screens.
         HyperlinkLicense shows license as inline hyperlink.
    -->
    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
          LicenseUrl="https://poseidon.local/license"
          Theme="hyperlinkLargeLicense"
          LogoFile="Resources\Poseidon.ico"
         LocalizationFile="BundleStrings_fr.wxl"
          SuppressOptionsUI="yes"/>
    </BootstrapperApplication>

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         CHAIN â€” Install order
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         Items are installed top-to-bottom.
         Prerequisites first, then the main MSI.
    -->
    <Chain DisableSystemRestore="yes">

      <!-- â”€â”€ Prerequisite 1: VC++ Redistributable 2022 (x64) â”€â”€
           Required by llama.cpp / LLamaSharp native binaries.
           Detect via registry; skip if already installed.
      -->
      <ExePackage
          Id="VCRedist"
                         SourceFile="prereqs\vc_redist.x64.exe"
                         InstallArguments="/install /quiet /norestart"
                         RepairArguments="/repair /quiet /norestart"
                         UninstallArguments="/uninstall /quiet /norestart"
          PerMachine="yes"
          Vital="yes"
          Permanent="yes"
                         DetectCondition="VCRedistInstalled" />

      <!-- â”€â”€ Prerequisite 2: .NET 8 Desktop Runtime (x64) â”€â”€
           Safety net for framework-dependent builds and tools.
           DetectCondition checks for host version 8.0+.
      -->
      <ExePackage
          Id="DotNet8Runtime"
                         SourceFile="prereqs\windowsdesktop-runtime-8.0-win-x64.exe"
                         InstallArguments="/install /quiet /norestart"
                         RepairArguments="/repair /quiet /norestart"
          PerMachine="yes"
          Vital="no"
          Permanent="yes"
                         DetectCondition="DotNetHostVersion AND DotNetHostVersion &gt;= v8.0.0" />

      <?if $(var.InstallerMode) = full And $(var.ExternalLlmPayload) = true ?>
      <!--
           Always run the helper. It is idempotent and performs SHA-256 detection
           internally, so repair can recover a missing or tampered model payload.
      -->
      <ExePackage
          Id="PoseidonExternalLlmPayload"
                         SourceFile="$(var.ModelPayloadInstallerPath)"
                         InstallArguments="--source &quot;[WixBundleOriginalSourceFolder]payload\Models&quot; --file &quot;$(var.LlmModelFileName)&quot; --sha256 &quot;$(var.LlmModelSha256)&quot;"
          PerMachine="yes"
          Vital="yes"
          Permanent="yes"
          DetectCondition="0" />
      <?endif?>

      <!-- â”€â”€ Main Application MSI â”€â”€ -->
      <MsiPackage
          Id="PoseidonMsi"
          SourceFile="$(var.MsiSourcePath)"
          Vital="yes"
                         ForcePerMachine="yes" />

    </Chain>

  </Bundle>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       Detection conditions
       â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Fragment>
    <!-- VC++ 2015-2022 Redistributable x64: check Installed DWORD = 1 -->
    <util:RegistrySearch
        Id="VCRedistSearch"
        Root="HKLM"
        Key="SOFTWARE\Microsoft\VisualStudio\14.0\VC\Runtimes\X64"
        Value="Installed"
        Result="value"
        Variable="VCRedistInstalled"/>

     <!-- .NET 8 Desktop Runtime presence (host version >= 8.0.0) -->
     <util:RegistrySearch
          Id="DotNetHostVersionSearch"
          Root="HKLM"
          Key="SOFTWARE\dotnet\Setup\InstalledVersions\x64\sharedhost"
          Value="Version"
          Result="value"
          Variable="DotNetHostVersion"/>
  </Fragment>

</Wix>

