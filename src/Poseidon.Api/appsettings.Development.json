{
  "Instance": {
    "Name": "Poseidon-Dev",
    "Id": "dev",
    "Environment": "Development"
  },
  "Domain": {
    "ActiveModule": "legal"
  },
  "Auth": {
    "Jwt": {
      "Issuer": "Poseidon-Dev",
      "Audience": "Poseidon.Client",
      "SigningKey": "POSEIDON_DEV_SIGNING_KEY_CHANGE_ME_1234567890",
      "ExpiryMinutes": 480
    }
  },
  "Security": {
    "AllowInsecureDevelopmentSecrets": true
  },
  "CentralManagement": {
    "Enabled": false,
    "BaseUrl": "http://localhost:5090",
    "ApiKey": "dev-local"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}

