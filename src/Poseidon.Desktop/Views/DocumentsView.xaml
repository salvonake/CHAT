<UserControl x:Class="Poseidon.Desktop.Views.DocumentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="LeftToRight"
             FontFamily="{StaticResource ArabicFont}"
             Background="{StaticResource BackgroundBrush}"
             AllowDrop="True"
             Drop="OnDrop"
             DragOver="OnDragOver">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Stats -->
            <RowDefinition Height="Auto"/>   <!-- Drop zone + actions -->
            <RowDefinition Height="Auto"/>   <!-- Ingestion progress -->
            <RowDefinition Height="*"/>      <!-- Document list -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════
             STATS ROW
             ══════════════════════════════ -->
        <UniformGrid Grid.Row="0" Columns="5" Margin="0,0,0,16">
            <!-- Total -->
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TotalDocuments}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource DocsTotal}"
                               Style="{StaticResource SecondaryText}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Indexed -->
            <Border Style="{StaticResource Card}" Margin="4,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding IndexedCount}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource SuccessBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource DocsIndexed}"
                               Style="{StaticResource SecondaryText}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Pending -->
            <Border Style="{StaticResource Card}" Margin="4,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding PendingCount}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource WarningBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource DocsPending}"
                               Style="{StaticResource SecondaryText}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Failed -->
            <Border Style="{StaticResource Card}" Margin="4,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding FailedCount}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource DangerBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource DocsFailed}"
                               Style="{StaticResource SecondaryText}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Vectors -->
            <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding VectorCount, StringFormat=N0}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource DocsVectors}"
                               Style="{StaticResource SecondaryText}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ══════════════════════════════
             DROP ZONE + ACTIONS
             ══════════════════════════════ -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Drop Zone -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2"
                    Background="{StaticResource SurfaceBrush}"
                    Margin="0,0,12,0"
                    CornerRadius="8"
                    Padding="16"
                    MinHeight="100">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📥"
                               FontSize="36"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource DocsDropZone}"
                               Style="{StaticResource SectionHeader}"
                               HorizontalAlignment="Center"
                               FontSize="18"/>
                    <TextBlock Text="{DynamicResource DocsDropSubtext}"
                               Style="{StaticResource SecondaryText}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="1" Width="180">
                <Button Content="{DynamicResource DocsBrowse}"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding IngestDirectoryCommand}"
                        Margin="0,0,0,8"/>

                <Button Content="{DynamicResource DocsIngestDir}"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding IngestWatchDirectoryCommand}"
                        Margin="0,0,0,8"/>

                <Button Content="{DynamicResource DocsOpenWatch}"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding OpenWatchDirectoryCommand}"
                        Margin="0,0,0,8"/>

                <Button Content="{DynamicResource DocsRefresh}"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding RefreshDocumentsCommand}"/>

                <!-- Case Namespace Filter -->
                <StackPanel Margin="0,12,0,0">
                    <TextBlock Text="{DynamicResource AskCaseNamespace}"
                               Style="{StaticResource SecondaryText}"
                               Margin="0,0,0,4"/>
                    <TextBox Text="{Binding SelectedCaseNamespace, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ArabicTextBox}"
                             FontSize="12"
                             Padding="8,6"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ══════════════════════════════
             INGESTION PROGRESS
             ══════════════════════════════ -->
        <Border Grid.Row="2"
                Style="{StaticResource Card}"
                Margin="0,0,0,12"
                Visibility="{Binding IsIngesting, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding IngestionStatus}"
                           Style="{StaticResource BodyText}"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,8"/>
                <ProgressBar Value="{Binding IngestionProgress}"
                             Maximum="{Binding IngestionTotal}"
                             Style="{StaticResource IngestionProgress}"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════
             DOCUMENT LIST
             ══════════════════════════════ -->
        <Border Grid.Row="3" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="{DynamicResource DocsTitle}"
                           Style="{StaticResource SectionHeader}"
                           FontSize="15"/>

                <DataGrid ItemsSource="{Binding Documents}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          FontFamily="{StaticResource ArabicFont}"
                          FontSize="13"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                          RowBackground="{StaticResource SurfaceBrush}"
                          AlternatingRowBackground="{StaticResource SurfaceLightBrush}"
                          HeadersVisibility="Column"
                          CanUserSortColumns="True"
                          SelectionMode="Single"
                          FlowDirection="LeftToRight">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter Property="FontFamily" Value="{StaticResource ArabicFont}"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="File Name"
                                           Binding="{Binding FileName}"
                                           Width="*"/>
                        <DataGridTextColumn Header="Status"
                                           Binding="{Binding StatusArabic}"
                                           Width="120"/>
                        <DataGridTextColumn Header="Case Namespace"
                                           Binding="{Binding CaseNamespace}"
                                           Width="120"/>
                        <DataGridTextColumn Header="Failure Attempts"
                                           Binding="{Binding FailureCount}"
                                           Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>


