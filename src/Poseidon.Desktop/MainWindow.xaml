<Window x:Class="Poseidon.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Poseidon.Desktop"
        xmlns:vm="clr-namespace:Poseidon.Desktop.ViewModels"
        xmlns:v="clr-namespace:Poseidon.Desktop.Views"
        mc:Ignorable="d"
        Title="Poseidon — LCDSS"
        Height="900" Width="1400"
        MinHeight="650" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        FlowDirection="LeftToRight"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <!-- ══ View DataTemplates ══ -->
        <DataTemplate DataType="{x:Type vm:AskViewModel}">
            <v:AskView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ChatViewModel}">
            <v:ChatView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DocumentsViewModel}">
            <v:DocumentsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <v:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HealthViewModel}">
            <v:HealthView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════
             Sidebar Navigation
             ══════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App Title -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,8">
                    <TextBlock Text="⚖️ LCDSS"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Poseidon"
                               FontSize="12"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                    <Separator Margin="0,12,0,0"
                               Background="{DynamicResource BorderBrush}" />
                </StackPanel>

                <!-- Status Bar (bottom) -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,12">
                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding VectorCount, StringFormat='📄 {0:N0} vectors'}"
                               FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,2,0,0" />
                    <TextBlock Text="{Binding GpuStatusText}"
                               FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,2,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GpuStatusText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding GpuStatusText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Navigation Buttons -->
                <StackPanel Margin="8,8,8,0">
                        <Button Content="📝  Legal Query"
                            Command="{Binding NavigateToAskCommand}"
                            Style="{DynamicResource NavButton}"
                            Margin="0,2" />
                        <Button Content="💬  Chat"
                            Command="{Binding NavigateToChatCommand}"
                            Style="{DynamicResource NavButton}"
                            Margin="0,2" />
                        <Button Content="📁  Documents"
                            Command="{Binding NavigateToDocumentsCommand}"
                            Style="{DynamicResource NavButton}"
                            Margin="0,2" />
                        <Button Content="⚙️  Settings"
                            Command="{Binding NavigateToSettingsCommand}"
                            Style="{DynamicResource NavButton}"
                            Margin="0,2" />
                        <Button Content="🩺  System Health"
                            Command="{Binding NavigateToHealthCommand}"
                            Style="{DynamicResource NavButton}"
                            Margin="0,2" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════
             Content Area
             ══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Enterprise Top Bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource HeroGradientBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Poseidon Enterprise"
                                   FontSize="19"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Evidence-constrained legal decision support"
                                   Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Style="{DynamicResource Card}"
                            Padding="10,5"
                            Background="{DynamicResource SurfaceLightBrush}">
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Encryption Warning Banner -->
            <Border Grid.Row="1"
                    Background="{DynamicResource DangerBrush}"
                    Padding="12,8"
                    Visibility="{Binding ShowEncryptionWarning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding EncryptionWarningText}"
                           Foreground="White" FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </Border>

            <!-- Model Status Banner -->
            <Border Grid.Row="2"
                    Background="{DynamicResource WarningBrush}"
                    Padding="12,8"
                    Visibility="{Binding ShowModelWarning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ModelWarningText}"
                           Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </Border>

            <!-- System Block Banner (fail-closed) -->
            <Border Grid.Row="3"
                    Background="#EE8B0000"
                    Padding="14,10"
                    Visibility="{Binding ShowSystemBlockBanner, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <StackPanel>
                    <TextBlock Text="Recovery mode - querying disabled"
                               Foreground="White" FontWeight="Bold"
                               FontSize="14" />
                    <TextBlock Text="{Binding SystemBlockReason}"
                               Foreground="#FFDDDDDD"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Active View Content -->
            <ContentControl Grid.Row="4"
                            Content="{Binding CurrentView}"
                            Margin="0" />
        </Grid>
    </Grid>
</Window>


