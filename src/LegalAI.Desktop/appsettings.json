{
  "Ui": {
    "Culture": "en-US",
    "MinimizeToTrayOnClose": true,
    "MinimizeToTrayOnMinimize": true,
    "ShowBackgroundNotifications": true
  },
  "Domain": {
    "ActiveModule": "legal"
  },
  "Llm": {
    "Provider": "llamasharp",
    "ModelPath": "",
    "GpuLayers": -1,
    "ContextSize": 8192,
    "Temperature": 0.1
  },
  "Ollama": {
    "Url": "http://localhost:11434",
    "Model": "qwen2.5:14b"
  },
  "Embedding": {
    "Provider": "onnx",
    "OnnxModelPath": "",
    "Model": "nomic-embed-text",
    "Dimension": 768
  },
  "Retrieval": {
    "TopK": 10,
    "SimilarityThreshold": 0.45,
    "AbstentionThreshold": 0.50,
    "StrictMode": true,
    "MaxContextTokens": 6000,
    "EnableDualPassValidation": true
  },
  "Security": {
    "EncryptionEnabled": false,
    "EncryptionPassphrase": ""
  },
  "Ingestion": {
    "WatchDirectory": "",
    "MaxParallelFiles": 4,
    "BatchSize": 32,
    "MaxFailuresBeforeQuarantine": 3,
    "WatcherThrottleMs": 5000,
    "WatcherDebounceMs": 2000
  },
  "ModelIntegrity": {
    "ExpectedLlmHash": "",
    "ExpectedEmbeddingHash": "",
    "RunStartupSelfTest": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "LegalAI.Security": "Debug",
        "LegalAI.Retrieval": "Debug"
      }
    }
  }
}
