<UserControl x:Class="LegalAI.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="LeftToRight"
             FontFamily="{StaticResource ArabicFont}"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16" MaxWidth="800">

            <!-- ══════════════════════════════
                 LANGUAGE
                 ══════════════════════════════ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Language"
                               Style="{StaticResource SectionHeader}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Default UI language:"
                                   Style="{StaticResource SecondaryText}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  SelectedValue="{Binding UiCulture}"
                                  SelectedValuePath="Tag"
                                  Background="{StaticResource SurfaceLightBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource ArabicFont}">
                            <ComboBoxItem Content="English (default)" Tag="en-US"/>
                            <ComboBoxItem Content="Arabic" Tag="ar"/>
                        </ComboBox>
                    </Grid>

                    <TextBlock Text="Language changes are applied after restart."
                               Style="{StaticResource SecondaryText}"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════
                 DESKTOP BEHAVIOR
                 ══════════════════════════════ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Desktop behavior"
                               Style="{StaticResource SectionHeader}"/>

                    <CheckBox Content="Minimize to tray when closing the window"
                              IsChecked="{Binding MinimizeToTrayOnClose}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontFamily="{StaticResource ArabicFont}"
                              Margin="0,0,0,10"/>

                    <CheckBox Content="Minimize to tray when pressing Minimize"
                              IsChecked="{Binding MinimizeToTrayOnMinimize}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontFamily="{StaticResource ArabicFont}"
                              Margin="0,0,0,10"/>

                    <CheckBox Content="Show background notifications"
                              IsChecked="{Binding ShowBackgroundNotifications}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontFamily="{StaticResource ArabicFont}"/>

                    <TextBlock Text="These options apply after restart."
                               Style="{StaticResource SecondaryText}"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════
                 ENCRYPTION
                 ══════════════════════════════ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource SettingsEncryption}"
                               Style="{StaticResource SectionHeader}"/>

                    <CheckBox Content="{DynamicResource SettingsEncEnable}"
                              IsChecked="{Binding EncryptionEnabled}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontFamily="{StaticResource ArabicFont}"
                              FontSize="14"
                              Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource SettingsPassphrase}"
                                   Style="{StaticResource SecondaryText}"
                                   Margin="0,0,0,4"/>
                        <PasswordBox x:Name="PassphraseBox"
                                     FontFamily="{StaticResource ArabicFont}"
                                     FontSize="14"
                                     Padding="12,10"
                                     Background="{StaticResource SurfaceLightBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     MaxLength="128"/>
                    </StackPanel>

                    <TextBlock Text="{Binding EncryptionStatus}"
                               Style="{StaticResource SecondaryText}"
                               Foreground="{StaticResource WarningBrush}"/>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════
                 MODEL PATHS
                 ══════════════════════════════ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource SettingsModel}"
                               Style="{StaticResource SectionHeader}"/>

                    <!-- LLM Provider -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="LLM provider:"
                                   Style="{StaticResource SecondaryText}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  SelectedValue="{Binding LlmProvider}"
                                  SelectedValuePath="Tag"
                                  Background="{StaticResource SurfaceLightBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource ArabicFont}">
                            <ComboBoxItem Content="LLamaSharp (embedded)" Tag="llamasharp"/>
                            <ComboBoxItem Content="Ollama (external)" Tag="ollama"/>
                        </ComboBox>
                    </Grid>

                    <!-- LLM Model Path -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource SettingsLlmPath}"
                                   Style="{StaticResource SecondaryText}"
                                   Margin="0,0,0,4"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Left"
                                    Content="{DynamicResource SettingsBrowse}"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding BrowseLlmModelCommand}"
                                    Margin="8,0,0,0"
                                    Padding="12,8"/>
                            <TextBox Text="{Binding LlmModelPath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ArabicTextBox}"
                                     FontSize="12"
                                     FlowDirection="LeftToRight"/>
                        </DockPanel>
                    </StackPanel>

                    <!-- Embedding Model Path -->
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource SettingsEmbPath}"
                                   Style="{StaticResource SecondaryText}"
                                   Margin="0,0,0,4"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Left"
                                    Content="{DynamicResource SettingsBrowse}"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding BrowseEmbeddingModelCommand}"
                                    Margin="8,0,0,0"
                                    Padding="12,8"/>
                            <TextBox Text="{Binding EmbeddingModelPath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ArabicTextBox}"
                                     FontSize="12"
                                     FlowDirection="LeftToRight"/>
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════
                 GPU SETTINGS
                 ══════════════════════════════ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource SettingsGpu}"
                               Style="{StaticResource SectionHeader}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="{DynamicResource SettingsGpuLayers}"
                                       Style="{StaticResource SecondaryText}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding GpuLayers, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ArabicTextBox}"
                                     FontSize="12"
                                     FlowDirection="LeftToRight"/>
                            <TextBlock Text="(-1 = all layers on GPU)"
                                       Style="{StaticResource SecondaryText}"
                                       FontSize="10"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="{DynamicResource SettingsContextSize}"
                                       Style="{StaticResource SecondaryText}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ContextSize, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ArabicTextBox}"
                                     FontSize="12"
                                     FlowDirection="LeftToRight"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════
                 RETRIEVAL SETTINGS
                 ══════════════════════════════ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource SettingsRetrieval}"
                               Style="{StaticResource SectionHeader}"/>

                    <UniformGrid Columns="3" Margin="0,0,0,12">
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="{DynamicResource SettingsTopK}"
                                       Style="{StaticResource SecondaryText}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding TopK, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ArabicTextBox}"
                                     FontSize="12"
                                     FlowDirection="LeftToRight"/>
                        </StackPanel>

                        <StackPanel Margin="4,0">
                            <TextBlock Text="{DynamicResource SettingsThreshold}"
                                       Style="{StaticResource SecondaryText}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SimilarityThreshold, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ArabicTextBox}"
                                     FontSize="12"
                                     FlowDirection="LeftToRight"/>
                        </StackPanel>

                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="{DynamicResource SettingsAbstention}"
                                       Style="{StaticResource SecondaryText}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding AbstentionThreshold, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ArabicTextBox}"
                                     FontSize="12"
                                     FlowDirection="LeftToRight"/>
                        </StackPanel>
                    </UniformGrid>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <CheckBox Content="{DynamicResource SettingsStrict}"
                                  IsChecked="{Binding StrictMode}"
                                  IsEnabled="False"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource ArabicFont}"
                                  Margin="0,0,8,0"/>
                        <TextBlock Text="🔒" FontSize="12" VerticalAlignment="Center"
                                   ToolTip="{Binding StrictModeLockReason}"/>
                        <TextBlock Text="(Locked — safety-critical system)"
                                   Style="{StaticResource SecondaryText}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,24,0"
                                   FontSize="11"/>
                        <CheckBox Content="{DynamicResource SettingsDualPass}"
                                  IsChecked="{Binding EnableDualPass}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource ArabicFont}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════
                 INGESTION SETTINGS
                 ══════════════════════════════ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource SettingsIngestion}"
                               Style="{StaticResource SectionHeader}"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource SettingsWatchDir}"
                                   Style="{StaticResource SecondaryText}"
                                   Margin="0,0,0,4"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Left"
                                    Content="{DynamicResource SettingsBrowse}"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding BrowseWatchDirectoryCommand}"
                                    Margin="8,0,0,0"
                                    Padding="12,8"/>
                            <TextBox Text="{Binding WatchDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ArabicTextBox}"
                                     FontSize="12"
                                     FlowDirection="LeftToRight"/>
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource SettingsParallel}"
                                   Style="{StaticResource SecondaryText}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding MaxParallelFiles, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ArabicTextBox}"
                                 FontSize="12"
                                 Width="100"
                                 HorizontalAlignment="Left"
                                 FlowDirection="LeftToRight"/>
                    </StackPanel>

                    <!-- Data Directory (read-only) -->
                    <StackPanel>
                        <TextBlock Text="{DynamicResource SettingsDataDir}"
                                   Style="{StaticResource SecondaryText}"
                                   Margin="0,0,0,4"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Left"
                                    Content="Open"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding OpenDataDirectoryCommand}"
                                    Margin="8,0,0,0"
                                    Padding="12,8"/>
                            <TextBox Text="{Binding DataDirectory, Mode=OneWay}"
                                     Style="{StaticResource ArabicTextBox}"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     FlowDirection="LeftToRight"/>
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════
                 SAVE BUTTON
                 ══════════════════════════════ -->
            <Button Content="{DynamicResource SettingsSave}"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveSettingsCommand}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,8"/>

            <TextBlock Text="{Binding SaveStatus}"
                       Style="{StaticResource BodyText}"
                       Foreground="{StaticResource SuccessBrush}"
                       Margin="0,0,0,24"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

