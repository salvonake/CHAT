<UserControl x:Class="LegalAI.Desktop.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LegalAI.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:ChatViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FlowDirection="LeftToRight"
             FontFamily="Segoe UI, Amiri, Arial"
             FontSize="14">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Inverse bool converter -->
        <vm:InverseBoolConverter x:Key="InvBool"/>

        <!-- Message alignment by role -->
        <vm:ChatRoleToAlignmentConverter x:Key="RoleAlign"/>
        <vm:ChatRoleToMarginConverter x:Key="RoleMargin"/>
        <vm:ChatRoleToBrushConverter x:Key="RoleBrush"/>
        <vm:ChatRoleToFgConverter x:Key="RoleFg"/>
        <vm:ChatRoleToCornerConverter x:Key="RoleCorner"/>

        <!-- ── Chat Bubble Template ── -->
        <DataTemplate x:Key="ChatBubbleTemplate" DataType="{x:Type vm:ChatMessage}">
            <Grid Margin="0,4" HorizontalAlignment="{Binding Role, Converter={StaticResource RoleAlign}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="{Binding Role, Converter={StaticResource RoleBrush}}"
                        CornerRadius="{Binding Role, Converter={StaticResource RoleCorner}}"
                        Padding="14,10"
                        Margin="{Binding Role, Converter={StaticResource RoleMargin}}"
                        MaxWidth="720"
                        MinWidth="80">
                    <StackPanel>
                        <!-- Role label -->
                        <TextBlock FontSize="11" Opacity="0.6"
                                   Foreground="{Binding Role, Converter={StaticResource RoleFg}}"
                                   Margin="0,0,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Role}" Value="User">
                                            <Setter Property="Text" Value="You"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                            <Setter Property="Text" Value="Legal Assistant"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Role}" Value="System">
                                            <Setter Property="Text" Value="System"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Message body -->
                        <TextBlock Text="{Binding Text}"
                                   TextWrapping="Wrap"
                                   Foreground="{Binding Role, Converter={StaticResource RoleFg}}"
                                   FontSize="14"
                                   LineHeight="22"/>

                        <!-- Streaming indicator -->
                        <TextBlock Text="⏳ Generating..."
                                   FontSize="12" Opacity="0.7"
                                   Foreground="{Binding Role, Converter={StaticResource RoleFg}}"
                                   Visibility="{Binding IsStreaming, Converter={StaticResource BoolVis}}"
                                   Margin="0,4,0,0"/>

                        <!-- Error indicator -->
                        <TextBlock Text="⚠ Error"
                                   FontSize="12" Foreground="#EF5350"
                                   Visibility="{Binding IsError, Converter={StaticResource BoolVis}}"
                                   Margin="0,4,0,0"/>

                        <!-- ── Confidence + Latency (assistant only) ── -->
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                    Visibility="{Binding IsCompleteAssistant, Converter={StaticResource BoolVis}}">
                            <Border Background="{Binding ConfidenceColor}"
                                    CornerRadius="4" Padding="6,2"
                                    Margin="0,0,8,0">
                                <TextBlock Text="{Binding ConfidenceLabel}"
                                           FontSize="11" Foreground="White"/>
                            </Border>
                            <TextBlock FontSize="11" Opacity="0.5"
                                       Foreground="{Binding Role, Converter={StaticResource RoleFg}}"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding LatencyMs, StringFormat={}{0:F0}ms}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- ── Safety Warning ── -->
                        <Border Background="#4DC62828" CornerRadius="4"
                                Padding="8,4" Margin="0,6,0,0"
                                Visibility="{Binding HasSafetyWarning, Converter={StaticResource BoolVis}}">
                            <StackPanel>
                                <TextBlock Text="{Binding SafetyWarningText}"
                                           Foreground="#EF5350" FontWeight="SemiBold"
                                           TextWrapping="Wrap" FontSize="12"/>
                                <ItemsControl ItemsSource="{Binding ValidationIssues}" Margin="4,2,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#EF9A9A"
                                                       FontSize="11" TextWrapping="Wrap" Margin="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ── Citation toggle button ── -->
                        <Button Content="{Binding Citations.Count, StringFormat=📎 {0} citations}"
                                FontSize="11" Cursor="Hand"
                                Visibility="{Binding HasCitations, Converter={StaticResource BoolVis}}"
                                Command="{Binding DataContext.ToggleCitationsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Margin="0,6,0,0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#90CAF9" HorizontalAlignment="Right"/>

                        <!-- ── Citations panel ── -->
                        <ItemsControl ItemsSource="{Binding Citations}"
                                      Visibility="{Binding ShowCitations, Converter={StaticResource BoolVis}}"
                                      Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1AFFFFFF" CornerRadius="4"
                                            Padding="8,6" Margin="0,2">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📄" FontSize="12" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"
                                                           Foreground="#90CAF9" FontSize="12"/>
                                                <TextBlock Text="{Binding PageNumber, StringFormat=Page {0}}"
                                                           Foreground="#AAA" FontSize="11" Margin="8,0,0,0"/>
                                                <TextBlock Text="{Binding SimilarityScore, StringFormat=({0:P0})}"
                                                           Foreground="#AAA" FontSize="11" Margin="8,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Content}"
                                                       TextWrapping="Wrap" FontSize="12"
                                                       Foreground="#CCC" Margin="0,4,0,0"
                                                       MaxHeight="80"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Warnings -->
                        <ItemsControl ItemsSource="{Binding Warnings}" Margin="0,4,0,0"
                                      Visibility="{Binding IsCompleteAssistant, Converter={StaticResource BoolVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#FFB74D"
                                               FontSize="11" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Timestamp -->
                        <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm}"
                                   FontSize="10" Opacity="0.4"
                                   Foreground="{Binding Role, Converter={StaticResource RoleFg}}"
                                   HorizontalAlignment="Left" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <!-- ── Library-Only overlay ── -->
        <Border Background="#E0000000" Panel.ZIndex="10"
                Visibility="{Binding IsLibraryOnlyMode, Converter={StaticResource BoolVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500">
                <TextBlock Text="⛔" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Library-only mode"
                           FontSize="24" FontWeight="Bold" Foreground="#EF5350"
                           HorizontalAlignment="Center" Margin="0,12,0,8"/>
                <TextBlock Text="{Binding LibraryOnlyReason}"
                           TextWrapping="Wrap" Foreground="#CCC" FontSize="14"
                           TextAlignment="Center" LineHeight="22"/>
                <TextBlock Text="Chat is disabled until the system is fully operational."
                           Foreground="#999" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Header -->
                <RowDefinition Height="*"/>      <!-- Messages -->
                <RowDefinition Height="Auto"/>   <!-- Input bar -->
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0" Background="#2D2D30" Padding="16,10">
                <DockPanel>
                    <Button DockPanel.Dock="Left"
                            Content="🗑 New chat"
                            Command="{Binding ClearChatCommand}"
                            Style="{StaticResource ButtonStyle}"
                            FontSize="12" Padding="12,6"
                            Background="#3C3C3C"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Case namespace:" Foreground="#999" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding CaseNamespace, UpdateSourceTrigger=PropertyChanged}"
                                 Width="180" FontSize="12"
                                 Style="{StaticResource TextBoxStyle}"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Messages list ── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          x:Name="MessagesScroll"
                          Background="#1E1E1E"
                          Padding="8,4">
                <ItemsControl ItemsSource="{Binding Messages}"
                              ItemTemplate="{StaticResource ChatBubbleTemplate}"
                              x:Name="MessagesControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- ── Input bar ── -->
            <Border Grid.Row="2" Background="#2D2D30" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource TextBoxStyle}"
                             FontSize="15"
                             MinHeight="40"
                             MaxHeight="120"
                             AcceptsReturn="False"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Center"
                             x:Name="InputBox">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SendMessageCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="1"
                            Command="{Binding SendMessageCommand}"
                            IsEnabled="{Binding IsProcessing, Converter={StaticResource InvBool}}"
                            Margin="8,0,0,0"
                            MinWidth="90" MinHeight="40"
                            FontSize="15">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
                                <Setter Property="Content" Value="Send ➤"/>
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                        <Setter Property="Content" Value="⏳"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Processing status below input -->
            </Border>

            <TextBlock Grid.Row="2"
                       Text="{Binding ProcessingStatus}"
                       Foreground="#666" FontSize="11"
                       Margin="16,0,0,4"
                       VerticalAlignment="Top"
                       Visibility="{Binding IsProcessing, Converter={StaticResource BoolVis}}"/>
        </Grid>
    </Grid>
</UserControl>

