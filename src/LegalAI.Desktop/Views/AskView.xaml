<UserControl x:Class="LegalAI.Desktop.Views.AskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="LeftToRight"
             FontFamily="{StaticResource ArabicFont}"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Library-only mode banner -->
            <RowDefinition Height="Auto"/>   <!-- LLM unavailable banner -->
            <RowDefinition Height="Auto"/>   <!-- Input area -->
            <RowDefinition Height="*"/>      <!-- Answer area -->
        </Grid.RowDefinitions>

        <!-- ── Library-Only Mode Overlay ── -->
        <Border Grid.Row="0"
                CornerRadius="6"
                Margin="0,0,0,12"
                Padding="16,12"
                Background="#3D0000"
                BorderBrush="{StaticResource DangerBrush}"
                BorderThickness="1"
                Visibility="{Binding IsLibraryOnlyMode, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="⛔ Library-only mode — legal querying disabled"
                           Style="{StaticResource BodyText}"
                           Foreground="{StaticResource DangerBrush}"
                           FontWeight="Bold"
                           FontSize="14"/>
                <TextBlock Text="{Binding LibraryOnlyReason}"
                           Style="{StaticResource BodyText}"
                           Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap"
                           Opacity="0.85"
                           Margin="0,6,0,0"/>
                <TextBlock Text="You can browse and manage documents, but asking questions is disabled until this issue is resolved."
                           Style="{StaticResource BodyText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── LLM Unavailable Banner ── -->
        <Border Grid.Row="1"
                Style="{StaticResource WarningBanner}"
                Visibility="{Binding LlmAvailable, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                CornerRadius="6"
                Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource AskLlmUnavailable}"
                       Style="{StaticResource BodyText}"
                       Foreground="{StaticResource DangerBrush}"/>
        </Border>

        <!-- ══════════════════════════════
             INPUT SECTION
             ══════════════════════════════ -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel>
                <!-- Question Input -->
                <TextBox Text="{Binding Question, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ArabicTextBox}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MinHeight="80"
                         MaxHeight="150"
                         VerticalScrollBarVisibility="Auto">
                    <!-- Placeholder via adorner not easily done in WPF, using Tag -->
                </TextBox>

                <!-- Options Row -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Case Namespace -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="{DynamicResource AskCaseNamespace}"
                                   Style="{StaticResource SecondaryText}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox Text="{Binding CaseNamespace, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ArabicTextBox}"
                                 Width="150"
                                 FontSize="12"
                                 Padding="8,6"/>
                    </StackPanel>

                    <!-- Strict Mode — Locked ON (fail-closed) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <CheckBox Content="{DynamicResource AskStrictMode}"
                                  IsChecked="{Binding StrictMode}"
                                  IsEnabled="False"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource ArabicFont}"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="🔒" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"
                                   ToolTip="Strict mode is always locked — safety-critical system"/>
                    </StackPanel>

                    <!-- TopK -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="TopK:"
                                   Style="{StaticResource SecondaryText}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   FlowDirection="LeftToRight"/>
                        <TextBox Text="{Binding TopK, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ArabicTextBox}"
                                 Width="50"
                                 FontSize="12"
                                 Padding="6,4"
                                 FlowDirection="LeftToRight"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <Button Grid.Column="4"
                            Content="{DynamicResource AskClear}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ClearAnswerCommand}"
                            Margin="0,0,8,0"/>

                    <Button Grid.Column="5"
                            Content="{DynamicResource AskButton}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding AskQuestionCommand}"
                            IsEnabled="{Binding IsProcessing, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                </Grid>

                <!-- Processing Status -->
                <TextBlock Text="{Binding ProcessingStatus}"
                           Style="{StaticResource SecondaryText}"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,8,0,0"
                           Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════
             ANSWER SECTION
             ══════════════════════════════ -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel Visibility="{Binding HasAnswer, Converter={StaticResource BoolToVis}}">

                <!-- Confidence Badge -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Border Style="{StaticResource StatusBadge}"
                                    Padding="12,4">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding ConfidenceColor}"/>
                                </Border.Background>
                                <TextBlock Text="{Binding ConfidenceLabel}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Text="{Binding LatencyMs, StringFormat={}{0:F0} ms}"
                                       Style="{StaticResource SecondaryText}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       FlowDirection="LeftToRight"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Abstention Message -->
                <Border Style="{StaticResource Card}"
                        Margin="0,0,0,12"
                        Background="#2D0000"
                        BorderBrush="{StaticResource DangerBrush}"
                        Visibility="{Binding IsAbstention, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource AskAbstention}"
                                   Style="{StaticResource SectionHeader}"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="16"/>
                        <TextBlock Text="{Binding AbstentionReason}"
                                   Style="{StaticResource BodyText}"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Answer Text -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Answer"
                                   Style="{StaticResource SectionHeader}"
                                   FontSize="15"/>
                        <TextBlock Text="{Binding AnswerText}"
                                   Style="{StaticResource BodyText}"
                                   FontSize="15"
                                   LineHeight="28"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Warnings -->
                <Border Style="{StaticResource Card}"
                        Margin="0,0,0,12"
                        Background="{StaticResource WarningBannerBrush}"
                        Visibility="{Binding Warnings.Count, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource AskWarnings}"
                                   Style="{StaticResource SectionHeader}"
                                   FontSize="14"
                                   Foreground="{StaticResource WarningBrush}"/>
                        <ItemsControl ItemsSource="{Binding Warnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Style="{StaticResource BodyText}"
                                               Foreground="{StaticResource WarningBrush}"
                                               Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Safety Validation Panel (fail-closed) -->
                <Border Style="{StaticResource Card}"
                        Margin="0,0,0,12"
                        BorderThickness="2"
                        Visibility="{Binding ShowSafetyWarning, Converter={StaticResource BoolToVis}}">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{Binding SafetyWarningColor}"/>
                    </Border.BorderBrush>
                    <Border.Background>
                        <SolidColorBrush Color="{Binding SafetyWarningColor}" Opacity="0.1"/>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="{Binding SafetyWarningText}"
                                   Style="{StaticResource SectionHeader}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="{Binding SafetyWarningColor}"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding ValidationIssues}" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Style="{StaticResource BodyText}"
                                               TextWrapping="Wrap"
                                               Margin="0,4">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{Binding DataContext.SafetyWarningColor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="⚖ Do not rely on this answer for legal decisions without independent review."
                                   Style="{StaticResource BodyText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Citations -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" FontSize="15">
                            <Run Text="{DynamicResource AskCitations}"/>
                            <Run Text=" ("/>
                            <Run Text="{Binding Citations.Count, Mode=OneWay}"/>
                            <Run Text=")"/>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding Citations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}"
                                            Margin="0,0,0,8"
                                            Background="{StaticResource SurfaceLightBrush}">
                                        <StackPanel>
                                            <!-- Citation Header -->
                                            <DockPanel Margin="0,0,0,8">
                                                <TextBlock DockPanel.Dock="Left"
                                                           Style="{StaticResource SecondaryText}">
                                                    <Run Text="{DynamicResource AskSimilarity}"/>
                                                    <Run Text=": "/>
                                                    <Run Text="{Binding SimilarityScore, StringFormat={}{0:P0}}"
                                                         Foreground="{StaticResource AccentBrush}"/>
                                                </TextBlock>
                                                <TextBlock Style="{StaticResource BodyText}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13">
                                                    <Run Text="📄 "/>
                                                    <Run Text="{Binding FileName}"/>
                                                    <Run Text=" — "/>
                                                    <Run Text="{DynamicResource AskPage}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding PageNumber}"/>
                                                </TextBlock>
                                            </DockPanel>

                                            <!-- Citation Content -->
                                            <TextBlock Text="{Binding Content}"
                                                       Style="{StaticResource BodyText}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       MaxHeight="100"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

