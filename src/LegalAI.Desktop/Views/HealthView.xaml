<UserControl x:Class="LegalAI.Desktop.Views.HealthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="LeftToRight"
             FontFamily="{StaticResource ArabicFont}"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16">

            <!-- ── Action Bar ── -->
            <DockPanel Margin="0,0,0,16">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="{DynamicResource HealthRefresh}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding RefreshAllCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource HealthVerifyAudit}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding VerifyAuditChainCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource HealthExportAudit}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportAuditLogCommand}"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           Style="{StaticResource SecondaryText}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left">
                    <Run Text="Last update: "/>
                    <Run Text="{Binding LastRefreshTime}"/>
                </TextBlock>
            </DockPanel>

            <!-- ══════════════════════════════
                 STATUS CARDS GRID
                 ══════════════════════════════ -->
            <UniformGrid Columns="3" Margin="0,0,0,16">

                <!-- LLM Status -->
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource HealthLlm}"
                                   Style="{StaticResource SectionHeader}"
                                   FontSize="14"/>
                        <TextBlock Text="{Binding LlmStatusText}"
                                   Style="{StaticResource BodyText}"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding LlmModelInfo}"
                                   Style="{StaticResource SecondaryText}"/>
                    </StackPanel>
                </Border>

                <!-- GPU Status -->
                <Border Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource HealthGpu}"
                                   Style="{StaticResource SectionHeader}"
                                   FontSize="14"/>
                        <TextBlock Text="{Binding GpuStatus}"
                                   Style="{StaticResource BodyText}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Encryption Status -->
                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource HealthEncryption}"
                                   Style="{StaticResource SectionHeader}"
                                   FontSize="14"/>
                        <TextBlock Text="{Binding EncryptionStatus}"
                                   Style="{StaticResource BodyText}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ══════════════════════════════
                 VECTOR STORE + DOCUMENTS
                 ══════════════════════════════ -->
            <UniformGrid Columns="2" Margin="0,0,0,16">

                <!-- Vector Store -->
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource HealthVectors}"
                                   Style="{StaticResource SectionHeader}"
                                   FontSize="14"/>
                        <TextBlock Text="{Binding VectorStoreStatus}"
                                   Style="{StaticResource BodyText}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Total vectors"
                                           Style="{StaticResource SecondaryText}"/>
                                <TextBlock Text="{Binding VectorCount, StringFormat=N0}"
                                           Style="{StaticResource BodyText}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Indexed chunks"
                                           Style="{StaticResource SecondaryText}"/>
                                <TextBlock Text="{Binding IndexedSegments, StringFormat=N0}"
                                           Style="{StaticResource BodyText}"
                                           FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Documents -->
                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource HealthDocs}"
                                   Style="{StaticResource SectionHeader}"
                                   FontSize="14"/>

                        <UniformGrid Columns="2" Rows="2">
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="Total"
                                           Style="{StaticResource SecondaryText}"/>
                                <TextBlock Text="{Binding TotalDocuments}"
                                           Style="{StaticResource BodyText}"
                                           FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="Indexed"
                                           Style="{StaticResource SecondaryText}"/>
                                <TextBlock Text="{Binding IndexedDocuments}"
                                           Style="{StaticResource BodyText}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessBrush}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Pending"
                                           Style="{StaticResource SecondaryText}"/>
                                <TextBlock Text="{Binding PendingDocuments}"
                                           Style="{StaticResource BodyText}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource WarningBrush}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Quarantined"
                                           Style="{StaticResource SecondaryText}"/>
                                <TextBlock Text="{Binding QuarantinedDocuments}"
                                           Style="{StaticResource BodyText}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource DangerBrush}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ══════════════════════════════
                 AUDIT CHAIN
                 ══════════════════════════════ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource HealthAudit}"
                               Style="{StaticResource SectionHeader}"
                               FontSize="14"/>
                    <TextBlock Text="{Binding AuditChainStatus}"
                               Style="{StaticResource BodyText}"
                               FontWeight="SemiBold"
                               FontSize="15"/>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════
                 METRICS TABLE
                 ══════════════════════════════ -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource HealthMetrics}"
                               Style="{StaticResource SectionHeader}"
                               FontSize="14"/>

                    <ItemsControl ItemsSource="{Binding MetricItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="8,10">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding Value}"
                                                   Style="{StaticResource BodyText}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FlowDirection="LeftToRight"
                                                   MinWidth="120"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding NameAr}"
                                                       Style="{StaticResource BodyText}"
                                                       FontSize="13"/>
                                            <TextBlock Text="{Binding NameEn}"
                                                       Style="{StaticResource SecondaryText}"
                                                       FontSize="11"
                                                       FlowDirection="LeftToRight"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>

